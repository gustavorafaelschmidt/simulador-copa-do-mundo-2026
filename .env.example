# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/simulador_copa_2026?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/simulador_copa_2026?schema=public"

# Auth.js / NextAuth v5
NEXTAUTH_SECRET="replace-me-with-a-secure-random-secret"
NEXTAUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# reCAPTCHA
RECAPTCHA_SECRET_KEY=""
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""

# Feature flags
PREDICTIONS_LOCKED="false"
ALLOW_OFFICIAL_DATA_PLACEHOLDERS="false"

# Socket.io
SOCKET_PORT="4001"
NEXT_PUBLIC_SOCKET_URL="http://localhost:4001"

# Storage provider selector: cloudinary | s3 | supabase | local
CLOUD_STORAGE_PROVIDER="local"

# Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# AWS S3
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET=""

# Supabase Storage
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_BUCKET=""

# Runtime
NODE_ENV="development"