{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@/components": [
        "components"
      ],
      "@/components/*": [
        "components/*"
      ],
      "@/lib": [
        "lib"
      ],
      "@/lib/*": [
        "lib/*"
      ],
      "@/services": [
        "services"
      ],
      "@/services/*": [
        "services/*"
      ],
      "@/actions": [
        "actions"
      ],
      "@/actions/*": [
        "actions/*"
      ],
      "@/types": [
        "types"
      ],
      "@/types/*": [
        "types/*"
      ],
      "@/contracts": [
        "lib/contracts"
      ],
      "@/contracts/*": [
        "lib/contracts/*"
      ],
      "@/prisma": [
        "prisma"
      ],
      "@/prisma/*": [
        "prisma/*"
      ],
      "@/auth": [
        "auth.ts"
      ]
    },
    "allowImportingTsExtensions": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "prisma/generated",
    ".next"
  ]
}
